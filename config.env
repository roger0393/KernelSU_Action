# ========== 源码 ==========
KERNEL_SOURCE=https://github.com/MiCode/Xiaomi_Kernel_OpenSource
KERNEL_SOURCE_BRANCH=peridot-u-oss

# ========== 内核配置 ==========
# peridot 基于 GKI，基础用 gki_defconfig，再用片段叠加
KERNEL_CONFIG=gki_defconfig
# 如果仓库支持片段功能（绝大多数版本不支持），否则需手动改脚本
# KERNEL_FRAGMENTS="arch/arm64/configs/vendor/peridot_GKI.config arch/arm64/configs/vendor/peridot_consolidate.config"

# ========== 编译产物 ==========
KERNEL_IMAGE_NAME=Image    # 现在大部分用 Image，不是 Image.gz-dtb
ARCH=arm64

# ========== KernelSU ==========
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5       # 按你想要的版本填

# ========== Docker 支持 ==========
# 如果脚本支持 ADDITIONAL_KCONFIG_FRAGMENTS 变量，可以加：
# ADDITIONAL_KCONFIG_FRAGMENTS=kernel_fragment/docker.config
# 否则需要在 build.sh 里手动合并 docker.config

# ========== 其他选项 ==========
DISABLE-LTO=false
DISABLE_CC_WERROR=false
ENABLE_CCACHE=true
